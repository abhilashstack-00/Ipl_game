# Backend port provided by your host (Render sets PORT automatically)
PORT=3002

# Comma-separated list of allowed frontend origins
# Example: FRONTEND_URLS=https://yourname.github.io/ipl-game,http://localhost:5173
FRONTEND_URLS=http://localhost:5173

# Keep this secret in production
JWT_SECRET=replace-with-a-strong-random-secret

# Optional live match provider (set to cricapi to enable live sync)
LIVE_MATCH_PROVIDER=

# API key for CricAPI when LIVE_MATCH_PROVIDER=cricapi
CRICAPI_KEY=

# Optional filter for series/name matching in provider payload
LIVE_SERIES_FILTER=ipl

# Poll cache window in milliseconds for live provider responses
# Lower values apply results faster but increase API calls
LIVE_CACHE_MS=15000

# Enable test-only helpers like auto-seeding a session for auction bypass
ALLOW_TEST_HELPER=false
